{
  "name": "aishwin-moodboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "workers:dev": "wrangler dev functions/index.js --port 8787",
    "workers:deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute mood-projects --file migrations/001_create_projects.sql",
    "db:init:prod": "wrangler d1 execute mood-projects-prod --file migrations/001_create_projects.sql"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "unsplash-js": "^7.0.20"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.4.0"
  }
}
